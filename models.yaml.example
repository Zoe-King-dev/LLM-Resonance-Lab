# LLM Resonance Lab — Model Registry Template
# ─────────────────────────────────────────────
# Copy this file to `models.yaml` and edit your real configuration:
#     cp models.yaml.example models.yaml
#
# `models.yaml` is .gitignored — your personal config stays local.
# NEVER paste an actual API key into this file. The `api_key_env` field
# must be the NAME of an environment variable (uppercase, underscores)
# that holds the real key. The loader will refuse to start if it detects
# what looks like a real key in this file.
#
# Field reference:
#   name           — friendly identifier used in CLI args and output filenames
#   provider       — LiteLLM provider prefix (e.g. "openai", "deepseek", "anthropic")
#   api_key_env    — NAME of env var holding the real API key (e.g. "OPENAI_API_KEY")
#   model_name     — (optional) ACTUAL model name the vendor's API expects.
#                    Sent verbatim in the request body. If unset, `name` is used.
#                    Use this when you want a friendly alias (`minimax3`) but the
#                    vendor's API expects a different identifier (`MiniMax-M3`).
#   api_base_env   — (optional) NAME of env var holding a custom API base URL.
#                    Use for OpenAI-compatible providers hosted on a non-default
#                    endpoint (e.g. `https://api.minimax.chat/v1`).

models:
  # Example 1: A built-in LiteLLM provider with default endpoint.
  - name: deepseek_v4
    provider: deepseek
    api_key_env: DEEPSEEK_API_KEY
    # model_name: deepseek-v4-flash   # uncomment if `name` is just an alias

  # Example 2: A custom OpenAI-compatible provider with explicit api_base.
  # The `provider: openai` tells LiteLLM to use the OpenAI protocol; the
  # `api_base` field redirects the request to the vendor's actual endpoint.
  - name: minimax3
    provider: openai
    api_key_env: MINIMAX_API_KEY
    model_name: MiniMax-M3
    api_base_env: MINIMAX_API_BASE
